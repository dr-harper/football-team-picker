rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // League cover images
    // Path: league-covers/{leagueId}/{userId}/{fileName}
    // Only the uploader's own subfolder is writable; anyone can read covers
    match /league-covers/{leagueId}/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
