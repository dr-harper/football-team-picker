rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // League cover images — authenticated users can upload, anyone can read
    match /league-covers/{leagueId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
