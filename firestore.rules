rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Any authenticated user can read profiles (needed to display member names in leagues)
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /pushSubscriptions/{subId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /leagues/{leagueId} {
      // Public read allows the join landing page to show league name before sign-up
      allow read:   if true;
      allow create: if request.auth != null;
      // Owner can update any field
      // Admins can update any field EXCEPT createdBy and adminIds (prevents privilege escalation)
      // Regular members can ONLY add themselves to memberIds (join flow)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy ||
        (
          resource.data.adminIds != null && request.auth.uid in resource.data.adminIds &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdBy', 'adminIds'])
        ) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.resource.data.memberIds.hasOnly(resource.data.memberIds.concat([request.auth.uid]))
        )
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    match /games/{gameId} {
      // Any authenticated user can read a game (needed for join-by-code flow)
      allow read: if request.auth != null;

      // Only league members can create games
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/leagues/$(request.resource.data.leagueId))
        && request.auth.uid in get(/databases/$(database)/documents/leagues/$(request.resource.data.leagueId)).data.memberIds;

      // Game creator or league admins can update; only creator can delete
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy ||
        (
          exists(/databases/$(database)/documents/leagues/$(resource.data.leagueId)) &&
          (
            request.auth.uid == get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)).data.createdBy ||
            (
              get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)).data.adminIds != null &&
              request.auth.uid in get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)).data.adminIds
            )
          )
        )
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    match /gameHealth/{docId} {
      // Owner can always read/write their own health data
      // Other authenticated users can read if shared == true
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        resource.data.shared == true
      );
      allow create, update: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /availability/{docId} {
      // Anyone in the league can read availability
      allow read: if request.auth != null;

      // Users can write their own availability; game creators can write any player's availability
      // Doc ID convention: {gameId}_{userId}
      allow write: if request.auth != null && (
        request.auth.uid == request.resource.data.userId ||
        (
          request.resource.data.gameId != null &&
          exists(/databases/$(database)/documents/games/$(request.resource.data.gameId)) &&
          request.auth.uid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.createdBy
        )
      );
    }
  }
}
